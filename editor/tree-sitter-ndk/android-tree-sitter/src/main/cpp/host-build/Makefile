	$(MAKE) $(MAKESILENT) -f CMakeFiles/android-tree-sitter.dir/build.make CMakeFiles/android-tree-sitter.dir/utils/ts_preconditions.cpp.s
.PHONY : utils/ts_preconditions.cpp.s

